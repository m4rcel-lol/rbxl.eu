<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — rbxl.eu</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/material.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="m3-body">
  <%- include('partials/nav') %>
  <main class="m3-main">
    <div class="m3-hero">
      <div class="m3-hero-content">
        <h1 class="m3-display-large">rbxl.eu</h1>
        <p class="m3-headline-small">Really Beautiful eXtraordinary Links</p>
        <p class="m3-body-large">Create your stunning personal bio page with Material You design.</p>
        <div class="m3-hero-actions">
          <% if (user) { %>
            <a href="/dashboard" class="m3-btn m3-btn-filled m3-btn-large">Go to Dashboard</a>
            <a href="/@<%= user.username %>" class="m3-btn m3-btn-tonal m3-btn-large">View Profile</a>
          <% } else { %>
            <a href="/register" class="m3-btn m3-btn-filled m3-btn-large">Get Started</a>
            <a href="/login" class="m3-btn m3-btn-outlined m3-btn-large">Login</a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="m3-container">
      <div class="m3-features-grid">
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">🎨</div>
            <h3 class="m3-title-large">Material You Design</h3>
            <p class="m3-body-medium">Beautiful, modern interface following Material Design 3 principles.</p>
          </div>
        </div>
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">🔗</div>
            <h3 class="m3-title-large">Custom Links</h3>
            <p class="m3-body-medium">Add all your social links, websites, and media in one place.</p>
          </div>
        </div>
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">⚡</div>
            <h3 class="m3-title-large">Lightning Fast</h3>
            <p class="m3-body-medium">Optimized for performance. Your profile loads instantly.</p>
          </div>
        </div>
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">🎵</div>
            <h3 class="m3-title-large">Media Embeds</h3>
            <p class="m3-body-medium">Embed YouTube, Spotify, SoundCloud and more on your profile.</p>
          </div>
        </div>
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">🏷️</div>
            <h3 class="m3-title-large">Unique Tags</h3>
            <p class="m3-body-medium">Stand out with your unique @username#0000 identity.</p>
          </div>
        </div>
        <div class="m3-card m3-card-elevated">
          <div class="m3-card-content">
            <div class="m3-feature-icon">🛡️</div>
            <h3 class="m3-title-large">Secure</h3>
            <p class="m3-body-medium">Built with security first — rate limiting, XSS protection, and more.</p>
          </div>
        </div>
      </div>
    </div>

    <footer class="m3-footer">
      <p>Built with ♥ using Material You &mdash; <a href="https://github.com/m4rcel-lol/rbxl.eu" class="m3-link">rbxl.eu</a></p>
    </footer>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
