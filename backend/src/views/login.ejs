<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — rbxl.eu</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/material.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="m3-body">
  <%- include('partials/nav') %>
  <main class="m3-main">
    <div class="m3-auth-container">
      <div class="m3-card m3-card-elevated m3-auth-card">
        <div class="m3-card-content">
          <h1 class="m3-headline-medium">Welcome back</h1>
          <p class="m3-body-medium">Sign in to your rbxl.eu account</p>

          <% if (error) { %>
            <div class="m3-alert m3-alert-error"><%= error %></div>
          <% } %>

          <form method="POST" action="/login" class="m3-form">
            <%- include('partials/csrf') %>
            <div class="m3-field">
              <label class="m3-label" for="username">Username</label>
              <input type="text" id="username" name="username" class="m3-input" required autocomplete="username">
            </div>
            <div class="m3-field">
              <label class="m3-label" for="password">Password</label>
              <input type="password" id="password" name="password" class="m3-input" required autocomplete="current-password">
            </div>
            <button type="submit" class="m3-btn m3-btn-filled m3-btn-full">Sign In</button>
          </form>

          <p class="m3-body-medium m3-text-center">
            Don't have an account? <a href="/register" class="m3-link">Sign up</a>
          </p>
        </div>
      </div>
    </div>
  </main>
  <script src="/js/app.js"></script>
</body>
</html>
